API_PORT=5174
SQLITE_DB_PATH=./data/xfn-dashboard.sqlite

# Remote MCP server. Use this for Atlassian/Rovo or an internal HTTP MCP gateway.
JIRA_MCP_URL=
JIRA_MCP_TRANSPORT=streamable-http
JIRA_MCP_BEARER_TOKEN=

# Local stdio MCP server. If set, this takes precedence over JIRA_MCP_URL.
JIRA_MCP_COMMAND=node
JIRA_MCP_ARGS=["server/localJiraMcp.js"]
JIRA_MCP_ENV={}

# Jira query and tool configuration. Override tool names if your MCP exposes different names.
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_MCP_ISSUE_TOOL=jira_search,jira_search_issues,search_jira_issues,jira_jql_search
JIRA_MCP_JQL=project = XFN ORDER BY updated DESC
JIRA_MCP_LIMIT=100
JIRA_MCP_FIELDS=summary,status,priority,labels,components,description,updated
JIRA_MCP_ISSUE_ARGS={}

# Optional Confluence lookup for XFN pages.
CONFLUENCE_MCP_SEARCH_TOOL=confluence_search,confluence_search_pages,search_confluence
CONFLUENCE_MCP_QUERY=
CONFLUENCE_MCP_LIMIT=25
CONFLUENCE_MCP_ARGS={}

# Map Jira custom fields into dashboard columns.
XFN_FIELD_TEAM=
XFN_FIELD_GROUP=
XFN_FIELD_SPRINT=
XFN_FIELD_PRODUCT_GOAL=
XFN_FIELD_SPRINT_GOAL=
XFN_FIELD_GOAL_MET=
XFN_FIELD_HEALTH=
XFN_FIELD_RISK_LEVEL=
XFN_FIELD_RISKS=
XFN_FIELD_NEEDS=
XFN_FIELD_IMPACTS=
XFN_FIELD_PROGRESS=
XFN_FIELD_CONFIDENCE=
