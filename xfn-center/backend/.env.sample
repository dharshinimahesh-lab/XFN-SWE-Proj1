JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=your.email@example.com
JIRA_API_TOKEN=replace-with-your-atlassian-api-token
JIRA_DEFAULT_PROJECT=ALLI

# Use "hybrid" for REST-backed Jira data plus non-blocking MCP enrichment.
# Other options: "rest" or "mcp".
JIRA_DATA_SOURCE=hybrid
JIRA_MCP_URL=https://mcp.atlassian.com/v1/mcp
JIRA_MCP_AUTH_MODE=basic

# Optional. If omitted, the backend asks Atlassian MCP for accessible resources.
ATLASSIAN_CLOUD_ID=

APP_HOST=127.0.0.1
APP_PORT=5001
APP_DEBUG=1
